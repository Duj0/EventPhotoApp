<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EventPhotoApp.Pages.HomePage"
    BackgroundColor="#1A1A2E"
    Title="Home Page">
    <ScrollView>
        <StackLayout Padding="30" Spacing="20" VerticalOptions="Center">
            <Image Source="snapshotlogo.png" HeightRequest="150" HorizontalOptions="Center"/>
            <Label Text="EventSnap"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Share your memories!!!"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"/>
            <Button Command="{Binding CreateEventCommand}" 
                    Text="Create Event" TextColor="White" BackgroundColor="#7C4DFF" BorderColor="#1A1A2E"/>
                    
            <Button Command="{Binding PhotosPageCommand}" 
                    Text="Gallery" TextColor="White" BackgroundColor="#7C4DFF" BorderColor="#1A1A2E"/>

            <Button Text="Join Event" TextColor="White" BackgroundColor="#7C4DFF" BorderColor="#1A1A2E"
                Command="{Binding JoinEventCommand}"/>
                
        </StackLayout>
    </ScrollView>
</ContentPage>