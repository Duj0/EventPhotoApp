<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventPhotoApp.Pages.JoinEventPage"
             BackgroundColor="#1A1A2E"
             Title="Join Event">
    <ScrollView>
        <StackLayout Padding="30" Spacing="15" VerticalOptions="Center">
            <Label Text="Join Event" 
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   Padding="0,20,0,10"/>
            <Label Text="Enter the event code"
                   FontSize="14"
                   TextColor="#AAAAAA"
                   HorizontalTextAlignment="Center"/>
            <Entry x:Name="CodeEntry"
                   TextColor="White"
                   PlaceholderColor="#AAAAAA"
                   Placeholder="Enter 6-digit code"
                   BackgroundColor="#2A2A3E"
                   HorizontalTextAlignment="Center"
                   FontSize="24"
                   Keyboard="Numeric"/>
            <Button Text="Join Event"
                    Clicked="OnSubmitEventClicked"
                    BackgroundColor="#7C4DFF"
                    TextColor="White"
                    CornerRadius="10"
                    Margin="0,20,0,0"/>
        </StackLayout>
    </ScrollView>
</ContentPage>